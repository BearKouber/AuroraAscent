---
const today = new Date();
---

<footer>
	<div><strong>AuroraAscent</strong><span>记录正在发生的成长。</span></div>
	<p>© {today.getFullYear()} auroraascent.cyou</p>
</footer>
<style>
	footer { display: flex; justify-content: space-between; gap: 1rem; max-width: 1120px; width: min(100% - 2.5rem, 1120px); margin: 0 auto; padding: 2rem 0 3rem; border-top: 1px solid var(--line); color: var(--muted); font-size: .82rem; }
	footer strong { color: var(--ink); font-family: var(--font-display); margin-right: .8rem; }
	footer p { margin: 0; }
	@media (max-width: 720px) { footer { width: min(100% - 2rem, 1120px); flex-direction: column; } }
</style>
