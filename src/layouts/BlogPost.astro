---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

type Props = CollectionEntry<'blog'>['data'];
const { title, description, pubDate, updatedDate } = Astro.props;
---
<!doctype html>
<html lang="zh-CN">
	<head><BaseHead title={`${title} · ${SITE_TITLE}`} description={description} /></head>
	<body>
		<Header />
		<main>
			<article>
				<a class="back" href="/blog">← 返回文章</a>
				<header class="article-header"><p class="date"><FormattedDate date={pubDate} />{updatedDate && <> · 更新于 <FormattedDate date={updatedDate} /></>}</p><h1>{title}</h1><p class="description">{description}</p></header>
				<div class="prose"><slot /></div>
			</article>
		</main>
		<Footer />
	</body>
</html>
<style>
article{width:min(100%,760px);margin:0 auto}.back{color:var(--aurora);font-size:.9rem;font-weight:700;text-decoration:none}.article-header{padding:4rem 0 2.5rem;border-bottom:1px solid var(--line)}.date{margin:0 0 1.2rem;color:var(--muted);font-size:.85rem}.article-header h1{margin:0}.description{max-width:580px;margin:1.5rem 0 0;color:var(--muted);font-size:1.1rem}.prose{padding-top:2.5rem}.prose :global(h2){margin-top:3rem;font-size:2rem}.prose :global(h3){margin-top:2rem}.prose :global(img){display:block;margin:2rem auto;border:1px solid var(--line)}
</style>
