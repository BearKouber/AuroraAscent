---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);
---

<!doctype html>
<html lang="zh-CN">
	<head><BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} /></head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="eyebrow">个人数字花园 · zerokitty.cyou</p>
				<h1>向着微光，<br /><em>持续生长。</em></h1>
				<p class="intro">AuroraAscent 是一个记录学习、构建与思考的个人空间。先把每一次前进留住，再看见更远的地方。</p>
				<div class="actions"><a class="primary" href="/blog">阅读文章 <span>→</span></a><a class="quiet" href="/about">认识我</a></div>
			</section>

			<section class="latest" aria-labelledby="latest-title">
				<div class="section-heading"><p class="eyebrow">最近更新</p><h2 id="latest-title">从这里开始</h2></div>
				{posts.length > 0 ? <ol class="post-list">{posts.map((post, index) => <li><a href={`/blog/${post.id}/`}><span class="index">0{index + 1}</span><div><h3>{post.data.title}</h3><p>{post.data.description}</p></div><time><FormattedDate date={post.data.pubDate} /></time><span class="arrow">↗</span></a></li>)}</ol> : <p class="empty">第一篇文章正在路上。</p>}
				<a class="all-posts" href="/blog">所有文章 <span>→</span></a>
			</section>

			<section class="future"><p class="eyebrow">持续构建</p><h2>这里也会慢慢长成<br />我的小型工作台。</h2><p>项目、目标、记录与实用的小工具，都会从这里开始。</p><a href="/projects">查看项目页 →</a></section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero { min-height: 64vh; padding: clamp(2rem, 8vw, 7rem) 0; display: flex; flex-direction: column; justify-content: center; }
	.eyebrow { margin: 0 0 1rem; color: var(--aurora); font-size: .76rem; font-weight: 700; letter-spacing: .12em; }
	h1 { max-width: 850px; margin: 0; }
	h1 em { color: var(--aurora); font-style: italic; }
	.intro { max-width: 520px; margin: 2rem 0 0; color: var(--muted); font-size: 1.1rem; }
	.actions { display: flex; align-items: center; gap: 1.5rem; margin-top: 2.2rem; }
	.primary { padding: .65rem 1rem; color: white; background: var(--aurora); text-decoration: none; transition: background .2s ease, transform .2s ease; }
	.primary:hover { color: white; background: #105449; transform: translateY(-2px); }
	.primary span, .all-posts span { margin-left: .5rem; }
	.quiet { color: var(--muted); }
	.latest { padding: 4.5rem 0; border-top: 1px solid var(--line); }
	.section-heading { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 1.5rem; }
	.section-heading h2, .future h2 { margin: 0; }
	.post-list { margin: 0; padding: 0; list-style: none; border-top: 1px solid var(--line); }
	.post-list li { border-bottom: 1px solid var(--line); }
	.post-list a { display: grid; grid-template-columns: 3rem 1fr auto 1.25rem; gap: 1.2rem; align-items: center; padding: 1.4rem 0; text-decoration: none; }
	.post-list a:hover h3, .post-list a:hover .arrow { color: var(--aurora); }
	.post-list h3 { margin: 0; font-size: 1.35rem; }
	.post-list p, time, .index { margin: .15rem 0 0; color: var(--muted); font-size: .88rem; }
	.index { color: var(--aurora); font-family: monospace; }
	.arrow { font-size: 1.35rem; transition: transform .2s ease; }.post-list a:hover .arrow { transform: translate(2px, -2px); }
	.all-posts { display: inline-block; margin-top: 1.5rem; color: var(--aurora); font-weight: 700; text-decoration: none; }
	.future { margin-top: 5rem; padding: clamp(2rem, 5vw, 4.5rem); color: var(--surface); background: var(--ink); }
	.future h2 { color: var(--surface); }.future p:not(.eyebrow) { max-width: 430px; margin-top: 1.5rem; color: #b6c1bc; }.future a { color: #a6d8c8; font-weight: 700; }
	@media (max-width: 720px) { .hero { min-height: 55vh; }.post-list a { grid-template-columns: 2rem 1fr 1rem; gap: .7rem; }.post-list time { display: none; }.post-list p { font-size: .8rem; }.section-heading { display: block; }.section-heading .eyebrow { margin-bottom: .4rem; } }
</style>