---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<!doctype html>
<html lang="zh-CN">
	<head><BaseHead title={`文章 · ${SITE_TITLE}`} description={SITE_DESCRIPTION} /></head>
	<body><Header /><main><p class="eyebrow">文章归档</p><h1>慢一点，<br />留下真正重要的。</h1><p class="intro">学习、构建和思考的过程，都值得被清楚地记录。</p><ol>{posts.map((post) => <li><a href={`/blog/${post.id}/`}><div><h2>{post.data.title}</h2><p>{post.data.description}</p></div><time><FormattedDate date={post.data.pubDate} /></time><span>↗</span></a></li>)}</ol></main><Footer /></body>
</html>
<style>
.eyebrow { margin:0; color:var(--aurora); font-size:.78rem; font-weight:700; letter-spacing:.12em; }.intro { max-width:540px; color:var(--muted); font-size:1.1rem; }h1{margin:.5rem 0 1.5rem}ol{margin:5rem 0 0;padding:0;list-style:none;border-top:1px solid var(--line)}li{border-bottom:1px solid var(--line)}li a{display:grid;grid-template-columns:1fr auto 1rem;gap:1.5rem;align-items:center;padding:1.6rem 0;text-decoration:none}h2{margin:0;font-size:1.45rem}li p,time{margin:.25rem 0 0;color:var(--muted);font-size:.9rem}li a:hover h2,li a:hover span{color:var(--aurora)}@media(max-width:720px){li a{grid-template-columns:1fr 1rem;gap:.7rem}time{display:none}}
</style>
